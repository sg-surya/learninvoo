{
    "name": "learnivo-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev:all": "npx concurrently -n frontend,backend -c cyan,yellow \"npm run dev:frontend\" \"npm run dev:backend\"",
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend && .\\venv\\Scripts\\python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
        "dev": "npm run dev:all",
        "install:frontend": "cd frontend && npm install",
        "install:all": "npm install && cd frontend && npm install"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}